# Docker
DOCKER_USERNAME=your_dockerhub_username

# Static files
STATIC_ROOT=/backend_static/static

# Django
SECRET_KEY=your-secret-key-must-be-50+chars-long-and-random
DEBUG=False
ALLOWED_HOSTS=.yourdomain.com,localhost,127.0.0.1

# CORS (нужен в production; в DEBUG=True все origins разрешаются автоматически)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Database
# USE_SQLITE=True  — раскомментировать для запуска без Docker
USE_SQLITE=False
POSTGRES_DB=your_database_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password_here
DB_HOST=db
DB_PORT=5432
